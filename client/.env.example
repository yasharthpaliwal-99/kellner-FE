# VM + nginx same-origin: leave these unset — app uses /api/* on the same host as the page.
#
# Only if UI and API are on different hosts:
# VITE_API_BASE_URL=https://other-host
# VITE_WS_BASE_URL=wss://other-host
# VITE_KELLNER_WS_URL=ws://127.0.0.1:8000/api/ws/conversation
#
# Local dev: Vite proxies /api to uvicorn (default port below).
# If client/.env sets VITE_API_BASE_URL to a remote host, add client/.env.local with:
#   VITE_API_BASE_URL=
# so the browser uses same-origin /api and the proxy hits 127.0.0.1:8000.
# VITE_KELLNER_API_PORT=8000

# Kitchen display: must match orders.hotel_id in Mongo (or use ?hotel_id= in the URL)
# VITE_HOTEL_ID=1
# Optional: filter one UTC calendar day — or add ?date=YYYY-MM-DD to the kitchen URL
