# FastAPI origin (no trailing slash). REQUIRED for production static hosts (Azure SWA, etc.);
# omit locally so /api/* is proxied by Vite to 127.0.0.1:8000.
# VITE_API_BASE_URL=https://your-backend-domain-or-ip
# Optional local fallback when VITE_API_BASE_URL is not set.
# VITE_KELLNER_API_PORT=8000

# Optional explicit websocket base (if set, /api/ws/conversation is auto-appended when needed).
# New key:
# VITE_WS_BASE_URL=wss://your-backend-domain-or-ip
# Legacy key (still supported):
# VITE_KELLNER_WS_URL=ws://127.0.0.1:8000/api/ws/conversation

# Kitchen display: must match orders.hotel_id in Mongo (or use ?hotel_id= in the URL)
# VITE_HOTEL_ID=1
# Optional: filter one UTC calendar day — or add ?date=YYYY-MM-DD to the kitchen URL
